{
  "name": "reusable-workflows",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/reusable-workflows.git"
  },
  "license": "UNLICENSED",
  "author": "WillBooster Inc.",
  "scripts": {
    "cleanup": "yarn format",
    "format": "sort-package-json",
    "postinstall": "husky || true",
    "pre-push": "echo 'start pre-push'; sleep 60; yarn sync",
    "prepare": "lefthook install || true",
    "sync": "one-way-git-sync -v -i node_modules -i renovate.json -d git@github.com:WillBoosterLab/reusable-workflows.git",
    "sync-force": "yarn sync --force",
    "verify": "wb verify",
    "verify-full": "wb verify --full"
  },
  "devDependencies": {
    "@willbooster/wb": "13.25.0",
    "lefthook": "2.1.9",
    "one-way-git-sync": "6.0.43",
    "sort-package-json": "4.0.0"
  },
  "packageManager": "yarn@4.17.1"
}
